    },
    {
        "id": "40237f028d37fd7e",
        "type": "http response",
        "z": "78e53885bf1abe0d",
        "g": "0a589b864fc903a5",
        "name": "Arm Response",
        "statusCode": "",
        "headers": {},
        "x": 620,
        "y": 700,
        "wires": []
    },
    {
        "id": "a5af3db4d8f8e61d",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "de2f393901718946",
        "name": "captureBaselineFromLastDistance",
        "func": "// Function node: captureBaselineFromLastDistance\nconst armed = flow.get(\"armed\");\nif (!armed || !msg.triggerBaseline) return null;\n\nconst last = flow.get(\"last\") || {};\nconst d = last.distanceCm;\n\nif (d === null || d === undefined || Number.isNaN(Number(d))) {\n    node.status({ fill: \"yellow\", shape: \"ring\", text: \"baseline waiting for ultrasonic reading\" });\n    return null;\n}\n\nconst baseline = { distanceCm: Number(d), capturedAt: Date.now() };\nflow.set(\"baseline\", baseline);\n\n// ensure we are in normal state after baseline is set\nflow.set(\"securityState\", \"normal\");\n\nconst statusPayload = {\n    armed: true,\n    state: \"normal\",\n    baseline,\n    ts: Date.now()\n};\n\nmsg.mqttTopic = \"vehicle/security/status\";\nmsg.mqttPayload = statusPayload;\n\nnode.status({ fill: \"green\", shape: \"dot\", text: `baseline=${baseline.distanceCm}cm` });\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
        "y": 960,
        "wires": [
            [
                "fc4d1caf9b1bc6ee",
                "5df9e2947c50bc28"
            ]
        ]
    },
    {
        "id": "f82d905a91cb1b3c",
