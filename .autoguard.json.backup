        "name": "Build Media Error Response",
        "func": "/**\n * Return a clean JSON error response for media read failures.\n */\nmsg.statusCode = 404;\nmsg.headers = {\n    \"Content-Type\": \"application/json\"\n};\n\nmsg.payload = {\n    ok: false,\n    error: \"Media file not found\",\n    details: msg.error?.message || \"Unknown media error\"\n};\n\nreturn msg;",
