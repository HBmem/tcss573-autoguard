    {
        "id": "b3ecbf97c400be84",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "459424595753cf62",
        "name": "Force Alarm Escalation",
        "func": "/**\n * Escalate an existing suspicious intrusion to alarm.\n * Keeps the original HTTP msg so the http response node can reply correctly.\n */\nconst now = Date.now();\nconst body = msg.payload || {};\nconst armed = Boolean(flow.get(\"armed\"));\nconst intrusion = flow.get(\"intrusion\") || {};\nlet state = flow.get(\"securityState\") || \"inactive\";\n\nif (!armed) {\n    msg.statusCode = 400;\n    msg.payload = { ok: false, error: \"System is not armed\", ts: now };\n    return [msg, null, null, null];\n}\n\nif (!intrusion.id || intrusion.status !== \"open\") {\n    msg.statusCode = 409;\n    msg.payload = { ok: false, error: \"No active intrusion available\", ts: now };\n    return [msg, null, null, null];\n}\n\nif (body.intrusionId && body.intrusionId !== intrusion.id) {\n    msg.statusCode = 409;\n    msg.payload = {\n        ok: false,\n        error: \"Intrusion ID mismatch\",\n        activeIntrusionId: intrusion.id,\n        requestedIntrusionId: body.intrusionId,\n        ts: now\n    };\n    return [msg, null, null, null];\n}\n\nif (state !== \"suspicious\") {\n    msg.statusCode = 409;\n    msg.payload = {\n        ok: false,\n        error: `Cannot escalate from state ${state}`,\n        ts: now\n    };\n    return [msg, null, null, null];\n}\n\nstate = \"alarm\";\nintrusion.lastEvidenceAt = now;\nintrusion.confirmedBy = Array.from(\n    new Set([...(intrusion.confirmedBy || []), \"dashboard_confirmed\"])\n);\n\nflow.set(\"securityState\", state);\nflow.set(\"intrusion\", intrusion);\n\nconst eventMsg = RED.util.cloneMessage(msg);\neventMsg.event = {\n    type: \"ALARM_ON\",\n    reason: \"user_requested_alarm\",\n    triggerSource: body.triggerSource || \"dashboard_user_confirmation\",\n    note: body.note || \"Alarm requested by dashboard\",\n    intrusionId: intrusion.id,\n    evidence: intrusion.confirmedBy,\n    picturePath: intrusion.picturePath || \"\",\n    videoPath: intrusion.videoPath || \"\",\n    armed: true,\n    state: \"alarm\",\n    ts: now\n};\neventMsg.statusUpdate = {\n    armed: true,\n    state: \"alarm\",\n    intrusionId: intrusion.id,\n    evidence: intrusion.confirmedBy,\n    ts: now\n};\n\nconst mqttMsg = RED.util.cloneMessage(msg);\nmqttMsg.topic = \"vehicle/security/status\";\nmqttMsg.payload = eventMsg.statusUpdate;\n\nmsg.statusCode = 200;\nmsg.payload = {\n    ok: true,\n    message: \"Alarm triggered\",\n    intrusionId: intrusion.id,\n    state: \"alarm\",\n    ts: now\n};\n\nreturn [msg, mqttMsg, eventMsg, eventMsg];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
