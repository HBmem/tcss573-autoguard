        "name": "Build Video File Path",
        "func": "/**\n * Build the absolute path for a video request.\n * Only allows safe filenames to prevent path traversal.\n *\n * Outputs:\n * 1 = valid file read request\n * 2 = immediate HTTP error response\n */\nconst filename = msg.req?.params?.filename || \"\";\n\nif (!/^[a-zA-Z0-9._-]+$/.test(filename)) {\n    msg.statusCode = 400;\n    msg.headers = {\n        \"Content-Type\": \"application/json\"\n    };\n    msg.payload = {\n        ok: false,\n        error: \"Invalid filename\"\n    };\n    return [null, msg];\n}\n\nmsg.filename = \"/home/pi/autoguard/videos/\" + filename;\nmsg.requestedFile = filename;\n\nreturn [msg, null];",
