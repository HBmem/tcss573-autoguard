    {
        "id": "f5dc23973c30ac07",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "71c8aa3b6b346885",
        "name": "Start Alarm State",
        "func": "/**\n * Start local alarm flashing/buzzing cycle.\n */\nflow.set(\"alarm\", {\n    active: true,\n    tickCount: 0,\n    ledState: 0\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
