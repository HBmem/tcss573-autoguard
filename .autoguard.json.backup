    },
    {
        "id": "72306b47b1bb7e82",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "be9c8d8a9e47d8d2",
        "name": "Capture Distance Baseline",
        "func": "/**\n * When the system is armed, capture the current distance as the driver-seat baseline.\n */\nconst now = Date.now();\nconst request = msg.payload || {};\nconst armed = Boolean(flow.get(\"armed\"));\nconst last = flow.get(\"last\") || {};\n\nif (!armed || !request.captureBaseline) {\n    return null;\n}\n\nif (last.distanceCm === null || last.distanceCm === undefined || Number.isNaN(last.distanceCm)) {\n    node.status({\n        fill: \"yellow\",\n        shape: \"ring\",\n        text: \"waiting for distance reading\"\n    });\n    return null;\n}\n\nconst baseline = {\n    distanceCm: Number(last.distanceCm),\n    capturedAt: now\n};\n\nflow.set(\"baseline\", baseline);\nflow.set(\"securityState\", \"active\");\n\nmsg.topic = \"vehicle/security/status\";\nmsg.payload = {\n    armed: true,\n    state: \"active\",\n    baseline,\n    ts: now\n};\n\nnode.status({\n    fill: \"green\",\n    shape: \"dot\",\n    text: `baseline ${baseline.distanceCm}cm`\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
