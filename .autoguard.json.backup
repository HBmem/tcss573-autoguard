    {
        "id": "8692d60c3afac9ea",
        "type": "grovepi-dht11",
        "z": "0e992f61a706eb58",
        "g": "6229e595b7e29330",
        "name": "Climate Sensor",
        "interval": "5",
        "unit": "s",
        "pin": "7",
        "sensorname": "DHT11",
        "sensorid": "dht11.1",
        "x": 1440,
