    {
        "id": "af7ecc15c77beeae",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "cb7a157e56d81ed1",
        "name": "normalizePi2Readings",
        "func": "// Function node: normalizePi2Readings\nconst p = msg.payload || {};\nconst now = Date.now();\nconst last = flow.get(\"last\") || {};\n\nif (p.vibration !== undefined) {\n    last.vibration = Number(p.vibration);\n    last.vibrationAt = p.ts ?? now;\n}\n\nif (p.sound !== undefined) {\n    last.sound = Number(p.sound);\n    last.soundAt = p.ts ?? now;\n}\n\nif (p.accel) {\n    const x = Number(p.accel.x ?? 0);\n    const y = Number(p.accel.y ?? 0);\n    const z = Number(p.accel.z ?? 0);\n    const mag = Math.sqrt(x * x + y * y + z * z);\n    last.accelMag = mag;\n    last.accelAt = p.ts ?? now;\n}\n\nflow.set(\"last\", last);\n\n// Also emit a normalized reading event for the engine\nmsg.reading = { sensor: \"pi2_bundle\", ts: p.ts ?? now, vibration: last.vibration, sound: last.sound, accelMag: last.accelMag };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
