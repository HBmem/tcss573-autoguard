    {
        "id": "da3690246efc2101",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "b494e1e3118ec541",
        "name": "buildInfluxEventPoint",
        "func": "// Function node: buildInfluxEventPoint\nconst ev = msg.event || {};\nconst last = flow.get(\"last\") || {};\nconst baseline = flow.get(\"baseline\") || {};\n\nmsg.payload = {\n    measurement: \"security_events\",\n    tags: {\n        device: \"pi1\",\n        intrusionId: ev.intrusionId || \"none\",\n        type: ev.type || \"unknown\"\n    },\n    fields: {\n        armed: 1,\n        state: String(ev.state || flow.get(\"securityState\") || \"unknown\"),\n        reason: String(ev.reason || \"\"),\n        evidence: JSON.stringify(ev.evidence || []),\n\n        // snapshot fields\n        distance_cm: last.distanceCm !== null ? Number(last.distanceCm) : null,\n        baseline_cm: baseline.distanceCm !== null ? Number(baseline.distanceCm) : null,\n        sound: last.sound !== null ? Number(last.sound) : null,\n        vibration: last.vibration !== null ? Number(last.vibration) : null,\n        accel_mag: last.accelMag !== null ? Number(last.accelMag) : null\n    },\n    timestamp: new Date(ev.ts || Date.now())\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
