    {
        "id": "a2403a2ffe650465",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "0f5c18efec07e0f7",
        "name": "getStatus",
        "func": "// Function node: GetStatus\nconst now = Date.now();\nconst intrusion = flow.get(\"intrusion\") || {\n  id: null,\n  startedAt: null,\n  lastEvidenceAt: null,\n  confirmedBy: [],\n  videoRecording: false,\n  status: \"closed\",\n  closedAt: null\n};\n\nconst last = flow.get(\"last\") || {};\n\nmsg.payload = {\n  armed: Boolean(flow.get(\"armed\")),\n  state: flow.get(\"securityState\") || \"inactive\",\n  baseline: flow.get(\"baseline\") || { distanceCm: null, capturedAt: null },\n  last: {\n    distanceCm: last.distanceCm ?? null,\n    sound: last.sound ?? null,\n    vibration: last.vibration ?? null,\n    accelMag: last.accelMag ?? null\n  },\n  intrusion,\n  ts: now\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
