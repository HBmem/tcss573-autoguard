        "x": 380,
        "y": 160,
        "wires": [
            []
        ]
    },
    {
        "id": "d9d56f37ce6d5202",
        "type": "http in",
        "z": "0e992f61a706eb58",
        "g": "75f65aa6282bdbfe",
        "name": "POST /api/arm",
        "url": "/api/arm",
        "method": "post",
        "upload": false,
        "skipBodyParsing": false,
        "swaggerDoc": "",
        "x": 160,
        "y": 300,
        "wires": [
            [
                "3e7c290b44363b6b"
            ]
        ]
    },
    {
        "id": "4bcc2a14d33814a7",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "75f65aa6282bdbfe",
        "name": "Handle Arm Request",
        "func": "/**\n * Arm or disarm the system.\n * When arming, the baseline is cleared and recaptured from the latest ultrasonic reading.\n * When disarming, any active alarm devices are explicitly shut down.\n * Preserves the original HTTP message for the http response node.\n */\nconst now = Date.now();\nconst body = msg.payload || {};\nconst armed = Boolean(body.armed);\n\nflow.set(\"armed\", armed);\nflow.set(\"seatStableSince\", null);\nflow.set(\"resolvedUntil\", null);\n\nlet alarmControlMsg = null;\n\nif (!armed) {\n    flow.set(\"securityState\", \"inactive\");\n    flow.set(\"baseline\", { distanceCm: null, capturedAt: null });\n    flow.set(\"intrusion\", {\n        id: null,\n        startedAt: null,\n        lastEvidenceAt: null,\n        confirmedBy: [],\n        status: \"closed\",\n        picturePath: null,\n        videoPath: null,\n        videoActive: false,\n        note: null,\n        closedAt: now\n    });\n    flow.set(\"alarm\", { active: false, tickCount: 0, ledState: 0 });\n\n    alarmControlMsg = RED.util.cloneMessage(msg);\n    alarmControlMsg.event = {\n        type: \"ALARM_OFF\",\n        reason: \"system_disarmed\",\n        note: \"System disarmed by user\",\n        intrusionId: null,\n        evidence: [],\n        state: \"inactive\",\n        ts: now\n    };\n    alarmControlMsg.statusUpdate = {\n        armed: false,\n        state: \"inactive\",\n        intrusionId: null,\n        evidence: [],\n        ts: now\n    };\n} else {\n    flow.set(\"securityState\", \"active\");\n    flow.set(\"baseline\", { distanceCm: null, capturedAt: null });\n}\n\nconst mqttMsg = RED.util.cloneMessage(msg);\nmqttMsg.topic = \"vehicle/security/status\";\nmqttMsg.payload = {\n    armed,\n    state: flow.get(\"securityState\"),\n    baseline: flow.get(\"baseline\"),\n    ts: now\n};\n\nconst baselineMsg = RED.util.cloneMessage(msg);\nbaselineMsg.payload = {\n    armed,\n    captureBaseline: armed,\n    ts: now\n};\n\nmsg.payload = {\n    ok: true,\n    armed,\n    state: flow.get(\"securityState\"),\n    baseline: flow.get(\"baseline\"),\n    ts: now\n};\n\nreturn [msg, mqttMsg, baselineMsg, alarmControlMsg];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
