    {
        "id": "8a85e827a930f392",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "71c8aa3b6b346885",
        "name": "Stop Alarm State",
        "func": "/**\n * Stop local alarm devices and reset state.\n */\nflow.set(\"alarm\", {\n    active: false,\n    tickCount: 0,\n    ledState: 0\n});\n\nreturn [\n    { payload: 0 },\n    { payload: 0 },\n    { reset: true }\n];",
