    {
        "id": "cc00ef4bd0747d06",
        "type": "inject",
        "z": "78e53885bf1abe0d",
        "g": "426fa63401e03052",
        "name": "Start Device",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 190,
        "y": 200,
        "wires": [
            [
                "8030fc6211711c5b"
            ]
        ]
    },
    {
        "id": "8030fc6211711c5b",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "426fa63401e03052",
        "name": "InitDefaults",
        "func": "// Function node: InitDefaults\n// Purpose: initialize shared state + tunables in flow context\n\nconst now = Date.now();\n\nif (flow.get(\"armed\") === undefined) flow.set(\"armed\", false);\nif (!flow.get(\"securityState\")) flow.set(\"securityState\", \"inactive\"); // inactive|normal|suspicious|alarm|resolved\nif (!flow.get(\"baseline\")) flow.set(\"baseline\", { distanceCm: null, capturedAt: null });\n\nif (!flow.get(\"last\")) {\n    flow.set(\"last\", {\n        distanceCm: null,\n        distanceAt: null,\n        sound: null,\n        soundAt: null,\n        vibration: null,\n        vibrationAt: null,\n        accelMag: null,\n        accelAt: null,\n    });\n}\n\nif (!flow.get(\"thresholds\")) {\n    flow.set(\"thresholds\", {\n        // occupancy detection using ultrasonic delta from baseline\n        seatDeltaCm: 10,           // change from baseline that implies someone in seat\n        seatDebounceMs: 1200,      // ignore rapid jitter (debouncing) :contentReference[oaicite:2]{index=2}\n\n        // sensor fusion confirmers\n        soundSpike: 140,           // adjust for your mic scale\n        vibrationSpike: 1,         // depends on your vibration sensor output\n        accelMagSpike: 1.8,        // magnitude threshold (g's or normalized) depending on sensor\n\n        // state timing\n        suspiciousHoldMs: 8000,    // how long we stay suspicious waiting for confirmation\n        alarmMinMs: 15000,         // minimum alarm time before allowing resolve\n    });\n}\n\nif (!flow.get(\"intrusion\")) {\n    flow.set(\"intrusion\", {\n        id: null,\n        startedAt: null,\n        lastEvidenceAt: null,\n        confirmedBy: [], // [\"ultrasonic\",\"sound\",\"vibration\",\"accel\"]\n        videoRecording: false\n    });\n}\n\nnode.status({ fill: \"grey\", shape: \"dot\", text: `armed=${flow.get(\"armed\")} state=${flow.get(\"securityState\")}` });\nmsg.payload = { ok: true, armed: flow.get(\"armed\"), state: flow.get(\"securityState\"), ts: now };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 200,
        "wires": [
            []
        ]
    },
    {
        "id": "34d1e37fcea063c8",
        "type": "grovepi-dht11",
        "z": "78e53885bf1abe0d",
        "g": "8f31da830bfc142b",
        "name": "Climate Sensor",
        "interval": "5",
        "unit": "s",
        "pin": "7",
        "sensorname": "DHT11",
        "sensorid": "dht11.1",
        "x": 180,
        "y": 360,
        "wires": [
            [
                "952d10bea95a8432"
            ]
        ]
    },
    {
        "id": "952d10bea95a8432",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "8f31da830bfc142b",
        "name": "formatClimate",
        "func": "// Function node: formatClimate\n// Writes a temperature point every interval, regardless of armed state.\n// Your notes call for continuous temp logging. :contentReference[oaicite:3]{index=3}\n\nconst t = msg.payload[0];\nconst h = msg.payload[1];\n\nmsg.payload = {\n    measurement: \"vehicle_cli\",\n    tags: { device: \"pi1\", sensor: \"dht11\" },\n    fields: {\n        temperature: Number(t),\n        humidity: Number(h)\n    },\n    timestamp: new Date()\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 360,
        "wires": [
            [
                "cb69ba197868d977"
            ]
        ]
    },
    {
        "id": "cb69ba197868d977",
        "type": "influxdb out",
        "z": "78e53885bf1abe0d",
        "g": "8f31da830bfc142b",
        "influxdb": "",
        "name": "",
        "measurement": "",
        "precision": "",
        "retentionPolicy": "",
        "database": "database",
        "precisionV18FluxV20": "ms",
        "retentionPolicyV18Flux": "",
        "org": "organisation",
        "bucket": "bucket",
        "x": 640,
        "y": 360,
        "wires": []
    },
    {
        "id": "24b93fc3dd7f26d8",
        "type": "grovepi-ultrasonic",
        "z": "78e53885bf1abe0d",
        "g": "bf9eea5de98d608c",
        "name": "Range Sensor",
        "mode": "timer",
        "interval": 1,
        "unit": "s",
        "pin": "5",
        "sensorname": "Ultrasonic Ranger",
        "sensorid": "grovepi.ultrasonic-ranger.1",
        "x": 170,
        "y": 520,
        "wires": [
            [
                "8a1ee34ddedd8c29"
            ]
        ]
    },
    {
        "id": "8a1ee34ddedd8c29",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "bf9eea5de98d608c",
        "name": "keepLastDistance",
        "func": "// Function node: keepLastDistance\nconst distanceCm = (typeof msg.payload === \"number\")\n    ? msg.payload\n    : Number(msg.payload?.distance ?? msg.payload?.cm);\n\nconst now = Date.now();\nconst last = flow.get(\"last\") || {};\nlast.distanceCm = distanceCm;\nlast.distanceAt = now;\nflow.set(\"last\", last);\n\n// also pass along a normalized reading for the engine\nmsg.reading = { sensor: \"ultrasonic\", distanceCm, ts: now };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 520,
        "wires": [
            [
                "0ff161bb8dacb2e6"
            ]
        ]
    },
    {
        "id": "5ef5331a716d070b",
        "type": "http in",
        "z": "78e53885bf1abe0d",
        "g": "0a589b864fc903a5",
        "name": "Arm System",
        "url": "/api/arm",
        "method": "post",
        "upload": false,
        "skipBodyParsing": false,
        "swaggerDoc": "",
        "x": 170,
        "y": 700,
        "wires": [
            [
                "564a27a5e47ef674"
            ]
        ]
    },
    {
        "id": "564a27a5e47ef674",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "0a589b864fc903a5",
        "name": "armDisarm",
        "func": "// Function node: armDisarm\nconst armed = Boolean(msg.payload?.armed);\nconst now = Date.now();\n\nflow.set(\"armed\", armed);\n\nif (!armed) {\n    flow.set(\"securityState\", \"inactive\");\n    flow.set(\"baseline\", { distanceCm: null, capturedAt: null });\n    flow.set(\"intrusion\", { id: null, startedAt: null, lastEvidenceAt: null, confirmedBy: [], videoRecording: false });\n} else {\n    // when armed, we enter normal once baseline is captured (Step 5)\n    flow.set(\"securityState\", \"normal\");\n}\n\nconst statusMsg = {\n    armed,\n    state: flow.get(\"securityState\"),\n    baseline: flow.get(\"baseline\"),\n    ts: now\n};\n\n// Publish to MQTT so Pi2 can react to state changes (QoS 1 recommended in your notes). :contentReference[oaicite:4]{index=4}\nmsg.mqttTopic = \"vehicle/security/status\";\nmsg.mqttPayload = statusMsg;\n\n// Response payload for dashboard\nmsg.payload = { ok: true, ...statusMsg };\n\n// Flag downstream baseline capture when arming\nmsg.triggerBaseline = armed;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 700,
        "wires": [
            [
                "273d1b3b25b4a7c2",
                "3a427980db1f8657",
                "40237f028d37fd7e"
            ]
        ]
    },
