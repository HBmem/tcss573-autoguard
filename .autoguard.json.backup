    {
        "id": "5ed829dd5aec70e3",
        "type": "mqtt in",
        "z": "78e53885bf1abe0d",
        "g": "cb7a157e56d81ed1",
        "name": "Pi 2 Sensor In",
        "topic": "vehicle/pi2/sensors",
        "qos": "2",
        "datatype": "auto-detect",
        "broker": "mqtt_broker_pi1",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 990,
        "y": 200,
        "wires": [
