        "g": "76f49feef62a3798",
        "name": "Update Settings",
        "func": "/**\n * Update configurable system settings.\n * Only approved settings are written back to flow context.\n */\nconst current = flow.get(\"settings\") || {};\nconst incoming = msg.payload || {};\n\nconst updated = {\n    ...current,\n    suspiciousModeEnabled: incoming.suspiciousModeEnabled !== undefined\n        ? Boolean(incoming.suspiciousModeEnabled)\n        : current.suspiciousModeEnabled,\n    seatDeltaCm: incoming.seatDeltaCm !== undefined\n        ? Number(incoming.seatDeltaCm)\n        : current.seatDeltaCm,\n    seatDebounceMs: incoming.seatDebounceMs !== undefined\n        ? Number(incoming.seatDebounceMs)\n        : current.seatDebounceMs,\n    soundSpike: incoming.soundSpike !== undefined\n        ? Number(incoming.soundSpike)\n        : current.soundSpike,\n    vibrationSpike: incoming.vibrationSpike !== undefined\n        ? Number(incoming.vibrationSpike)\n        : current.vibrationSpike,\n    accelMagSpike: incoming.accelMagSpike !== undefined\n        ? Number(incoming.accelMagSpike)\n        : current.accelMagSpike,\n    confirmWindowMs: incoming.confirmWindowMs !== undefined\n        ? Number(incoming.confirmWindowMs)\n        : current.confirmWindowMs,\n    suspiciousTimeoutMs: incoming.suspiciousTimeoutMs !== undefined\n        ? Number(incoming.suspiciousTimeoutMs)\n        : current.suspiciousTimeoutMs,\n    alarmMinMs: incoming.alarmMinMs !== undefined\n        ? Number(incoming.alarmMinMs)\n        : current.alarmMinMs,\n    autoResolveQuietMs: incoming.autoResolveQuietMs !== undefined\n        ? Number(incoming.autoResolveQuietMs)\n        : current.autoResolveQuietMs,\n    notificationPhone: incoming.notificationPhone ?? current.notificationPhone ?? \"\",\n    notificationEmail: incoming.notificationEmail ?? current.notificationEmail ?? \"\"\n};\n\nflow.set(\"settings\", updated);\n\nnode.send([\n    {\n        payload: {\n            ok: true,\n            settings: updated,\n            ts: Date.now()\n        }\n    },\n    {\n        topic: \"vehicle/security/settings\",\n        payload: {\n            settings: updated,\n            ts: Date.now()\n        }\n    }\n]);\n\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
