    {
        "id": "107f5053e5127f4a",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "6a072c52208fa8e8",
        "name": "buildCameraCommands",
        "func": "// Function node: buildCameraCommands\n// Builds msg.command for Exec node.\n// Adjust paths + command depending on your Pi camera stack.\n// We'll create a per-intrusion filename so you can later store/reference it.\n\nconst ev = msg.event || {};\nconst intrusionId = ev.intrusionId || `intr_${Date.now()}`;\n\nconst baseDir = \"/home/pi/vehicle_security\";\nconst vidPath = `${baseDir}/videos/${intrusionId}.h264`;\nconst pidPath = `${baseDir}/videos/${intrusionId}.pid`;\n\nif (ev.type === \"ALARM_ON\") {\n    // Start recording (background) and save PID so we can stop it.\n    // Option A: libcamera-vid (newer)\n    msg.command = `bash -lc 'mkdir -p ${baseDir}/videos && (libcamera-vid -t 0 -o ${vidPath} --inline --nopreview >/dev/null 2>&1 & echo $! > ${pidPath})'`;\n    msg.videoPath = vidPath;\n    return msg;\n}\n\nif (ev.type === \"ALARM_AUTO_RESOLVE\" || ev.type === \"ALARM_OFF\") {\n    // Stop recording if running\n    msg.command = `bash -lc 'if [ -f ${pidPath} ]; then kill $(cat ${pidPath}) >/dev/null 2>&1; rm -f ${pidPath}; fi'`;\n    msg.videoPath = vidPath;\n    return msg;\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
