    {
        "id": "e0185a457c0f36cb",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "6229e595b7e29330",
        "name": "Format Climate Reading",
        "func": "/**\n * Normalize DHT11 output and keep latest climate values in flow context.\n */\nconst now = Date.now();\nconst temperatureC = Number(msg.payload[0]);\nconst humidity = Number(msg.payload[1]);\n\nconst last = flow.get(\"last\") || {};\nlast.temperatureC = temperatureC;\nlast.humidity = humidity;\nlast.climateAt = now;\nflow.set(\"last\", last);\n\nnode.send([\n    {\n        payload: {\n            measurement: \"vehicle_climate\",\n            tags: {\n                device: \"pi1\",\n                sensor: \"dht11\"\n            },\n            fields: {\n                temperatureC,\n                humidity\n            },\n            timestamp: new Date(now)\n        }\n    },\n    {\n        payload: {\n            sensor: \"dht11\",\n            temperatureC,\n            humidity,\n            ts: now\n        }\n    }\n]);\n\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
