    {
        "id": "0b878342b55230f2",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "dfaa92d4dd849eab",
        "name": "Initialize System State",
        "func": "/**\n * Initialize all shared state used by GrovePi 1.\n * This node should run once on startup.\n */\nconst now = Date.now();\n\nconst defaults = {\n    armed: false,\n    securityState: \"inactive\", // inactive | active | suspicious | alarm | resolved\n    resolvedUntil: null,\n    settings: {\n        suspiciousModeEnabled: true,\n        seatDeltaCm: 10,\n        seatDebounceMs: 1200,\n        vibrationSpike: 1,\n        accelMagSpike: 1.8,\n        confirmWindowMs: 4000,\n        suspiciousTimeoutMs: 60000,\n        alarmMinMs: 15000,\n        autoResolveQuietMs: 6000,\n        notificationPhone: \"\",\n        notificationEmail: \"\"\n    },\n    baseline: {\n        distanceCm: null,\n        capturedAt: null\n    },\n    last: {\n        distanceCm: null,\n        distanceAt: null,\n        temperatureC: null,\n        humidity: null,\n        climateAt: null,\n        vibration: null,\n        vibrationAt: null,\n        accelMag: null,\n        accelAt: null\n    },\n    intrusion: {\n        id: null,\n        startedAt: null,\n        lastEvidenceAt: null,\n        confirmedBy: [],\n        status: \"closed\",\n        picturePath: null,\n        videoPath: null,\n        videoActive: false,\n        note: null,\n        closedAt: null\n    },\n    alarm: {\n        active: false,\n        tickCount: 0,\n        ledState: 0\n    },\n    liveFeedEvents: [],\n    seatStableSince: null\n};\n\nfor (const [key, value] of Object.entries(defaults)) {\n    if (flow.get(key) === undefined) {\n        flow.set(key, value);\n    }\n}\n\nnode.status({\n    fill: \"grey\",\n    shape: \"dot\",\n    text: `armed=${flow.get(\"armed\")} state=${flow.get(\"securityState\")}`\n});\n\nmsg.payload = {\n    ok: true,\n    armed: flow.get(\"armed\"),\n    state: flow.get(\"securityState\"),\n    ts: now\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
