    {
        "id": "8900cf9202efbd7a",
        "type": "trigger",
        "z": "0e992f61a706eb58",
        "g": "c3bc344f2852449d",
        "name": "Alarm Tick",
        "op1": "1",
        "op2": "0",
        "op1type": "num",
        "op2type": "str",
        "duration": "-0.5",
        "extend": false,
        "overrideDelay": false,
        "units": "s",
        "reset": "reset",
        "bytopic": "all",
        "topic": "topic",
        "outputs": 1,
        "x": 690,
        "y": 1160,
        "wires": [
            [
                "f9d162e9615d1636"
            ]
        ]
    },
    {
        "id": "f9d162e9615d1636",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "c3bc344f2852449d",
        "name": "Alarm Tick Router",
        "func": "/**\n * Alternate LED state and pulse buzzer while the alarm is active.\n */\nconst alarm = flow.get(\"alarm\") || { active: false, tickCount: 0, ledState: 0 };\n\nif (!alarm.active) {\n    return [null, null];\n}\n\nalarm.tickCount += 1;\nalarm.ledState = alarm.ledState ? 0 : 1;\nflow.set(\"alarm\", alarm);\n\nreturn [\n    { payload: 1 },\n    { payload: alarm.ledState }\n];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 890,
        "y": 1160,
        "wires": [
            [
                "faa613d260876a51"
            ],
            [
                "73598425fff63a7b"
            ]
        ]
    },
    {
        "id": "faa613d260876a51",
        "type": "grovepi-buzzer",
        "z": "0e992f61a706eb58",
        "g": "c3bc344f2852449d",
        "name": "Alarm Buzzer",
        "pin": "3",
        "x": 1100,
        "y": 1120,
        "wires": []
    },
    {
        "id": "73598425fff63a7b",
        "type": "grovepi-led",
        "z": "0e992f61a706eb58",
        "g": "c3bc344f2852449d",
        "name": "Alarm LED",
        "pin": "4",
        "x": 1090,
        "y": 1200,
        "wires": []
    },
    {
        "id": "a2e2b9722d48755b",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "6d15c9fd9f5b6e7e",
        "name": "Build Camera Commands",
        "func": "/**\n * Camera policy:\n * - INFO_SUSPICIOUS: capture a still image only\n * - ALARM_ON: start video recording as .h264\n * - ALARM_OFF: stop recording and convert .h264 -> .mp4\n *\n * Outputs:\n * 1 = Exec node\n * 2 = Dashboard live feed\n * 3 = Event persistence\n */\nconst event = msg.event || {};\nconst baseDir = \"/home/pi/autoguard\";\nconst scriptPath = `${baseDir}/camera_service.py`;\n\nlet intrusion = flow.get(\"intrusion\") || {\n    id: null,\n    startedAt: null,\n    lastEvidenceAt: null,\n    confirmedBy: [],\n    status: \"closed\",\n    picturePath: null,\n    videoPath: null,\n    videoActive: false,\n    note: null,\n    closedAt: null\n};\n\nconst activeIntrusionId = event.intrusionId || intrusion.id || null;\n\nconst imagePath = activeIntrusionId ? `${baseDir}/images/${activeIntrusionId}.jpg` : (intrusion.picturePath || \"\");\nconst h264Path = activeIntrusionId ? `${baseDir}/videos/${activeIntrusionId}.h264` : \"\";\nconst mp4Path = activeIntrusionId ? `${baseDir}/videos/${activeIntrusionId}.mp4` : (intrusion.videoPath || \"\");\nconst pidPath = activeIntrusionId ? `${baseDir}/videos/${activeIntrusionId}.pid` : \"\";\nconst logPath = activeIntrusionId\n    ? `/tmp/autoguard_camera_${activeIntrusionId}.log`\n    : `/tmp/autoguard_camera_generic.log`;\n\nconst liveFeedMsg = RED.util.cloneMessage(msg);\nconst persistenceMsg = RED.util.cloneMessage(msg);\nlet execMsg = null;\n\n// Suspicious -> capture picture only\nif (event.type === \"INFO_SUSPICIOUS\") {\n    if (!activeIntrusionId) {\n        return [null, null, null];\n    }\n\n    intrusion.id = intrusion.id || activeIntrusionId;\n    intrusion.picturePath = intrusion.picturePath || imagePath;\n    intrusion.videoPath = intrusion.videoPath || mp4Path;\n    intrusion.videoActive = false;\n    flow.set(\"intrusion\", intrusion);\n\n    liveFeedMsg.event.picturePath = intrusion.picturePath;\n    liveFeedMsg.event.videoPath = intrusion.videoPath || \"\";\n\n    persistenceMsg.event.picturePath = intrusion.picturePath;\n    persistenceMsg.event.videoPath = intrusion.videoPath || \"\";\n\n    execMsg = RED.util.cloneMessage(msg);\n    execMsg.payload = `-lc \"python3 ${scriptPath} capture-image --output '${intrusion.picturePath}' >'${logPath}' 2>&1\"`;\n\n    return [execMsg, liveFeedMsg, persistenceMsg];\n}\n\n// Alarm -> start video recording as h264\nif (event.type === \"ALARM_ON\") {\n    if (!activeIntrusionId) {\n        return [null, null, null];\n    }\n\n    intrusion.id = intrusion.id || activeIntrusionId;\n    intrusion.picturePath = intrusion.picturePath || imagePath;\n    intrusion.videoPath = intrusion.videoPath || mp4Path;\n    intrusion.videoActive = true;\n    flow.set(\"intrusion\", intrusion);\n\n    liveFeedMsg.event.picturePath = intrusion.picturePath;\n    liveFeedMsg.event.videoPath = intrusion.videoPath;\n\n    persistenceMsg.event.picturePath = intrusion.picturePath;\n    persistenceMsg.event.videoPath = intrusion.videoPath;\n\n    execMsg = RED.util.cloneMessage(msg);\n    execMsg.payload = `-lc \"python3 ${scriptPath} start-video --output '${h264Path}' --pid-file '${pidPath}' >'${logPath}' 2>&1 &\"`;\n\n    return [execMsg, liveFeedMsg, persistenceMsg];\n}\n\n// Resolve / timeout / disarm -> stop video and convert to mp4\nif (event.type === \"ALARM_OFF\") {\n    liveFeedMsg.event.picturePath = intrusion.picturePath || \"\";\n    liveFeedMsg.event.videoPath = intrusion.videoPath || \"\";\n\n    persistenceMsg.event.picturePath = intrusion.picturePath || \"\";\n    persistenceMsg.event.videoPath = intrusion.videoPath || \"\";\n\n    if (!intrusion.videoActive || !activeIntrusionId) {\n        return [null, liveFeedMsg, persistenceMsg];\n    }\n\n    const stopH264Path = `${baseDir}/videos/${activeIntrusionId}.h264`;\n    const stopMp4Path = `${baseDir}/videos/${activeIntrusionId}.mp4`;\n    const stopPidPath = `${baseDir}/videos/${activeIntrusionId}.pid`;\n\n    intrusion.videoActive = false;\n    intrusion.videoPath = stopMp4Path;\n    flow.set(\"intrusion\", intrusion);\n\n    execMsg = RED.util.cloneMessage(msg);\n    execMsg.payload = `-lc \"python3 ${scriptPath} stop-video --pid-file '${stopPidPath}' --h264-input '${stopH264Path}' --mp4-output '${stopMp4Path}' >'${logPath}' 2>&1\"`;\n\n    return [execMsg, liveFeedMsg, persistenceMsg];\n}\n\nreturn [null, null, null];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 1340,
        "wires": [
            [
                "fe886807dd77d494",
                "ad1c7710ab01be2b"
            ],
