    },
    {
        "id": "226598f4dab18300",
        "type": "http in",
        "z": "78e53885bf1abe0d",
        "g": "e87d4bb36e9eef97",
        "name": "POST Resolve",
        "url": "/api/resolve",
        "method": "post",
        "upload": false,
        "skipBodyParsing": false,
        "swaggerDoc": "",
        "x": 1760,
        "y": 940,
        "wires": [
            [
                "4da8dd1ec40489c6"
            ]
        ]
    },
    {
        "id": "4da8dd1ec40489c6",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "e87d4bb36e9eef97",
        "name": "resolveAlarm",
        "func": "// Function node: ResolveAlarm\nconst now = Date.now();\nconst armed = Boolean(flow.get(\"armed\"));\nlet state = flow.get(\"securityState\") || \"inactive\";\nlet intrusion = flow.get(\"intrusion\") || {\n    id: null,\n    startedAt: null,\n    lastEvidenceAt: null,\n    confirmedBy: [],\n    videoRecording: false,\n    status: \"closed\",\n    closedAt: null\n};\n\nconst note = msg.payload?.note || \"Resolved by user\";\nconst resolutionType = msg.payload?.resolutionType || \"user_resolved\";\nconst requestedIntrusionId = msg.payload?.intrusionId || null;\n\nif (!armed) {\n    msg.statusCode = 400;\n    msg.payload = { ok: false, error: \"System not armed\", ts: now };\n    return msg;\n}\n\nif (!intrusion.id || intrusion.status !== \"open\") {\n    msg.statusCode = 409;\n    msg.payload = { ok: false, error: \"No active intrusion to resolve\", ts: now };\n    return msg;\n}\n\nif (requestedIntrusionId && intrusion.id !== requestedIntrusionId) {\n    msg.statusCode = 409;\n    msg.payload = {\n        ok: false,\n        error: \"Intrusion ID does not match active intrusion\",\n        activeIntrusionId: intrusion.id,\n        requestedIntrusionId,\n        ts: now\n    };\n    return msg;\n}\n\n// Mark current intrusion resolved\nintrusion.status = \"resolved\";\nintrusion.closedAt = now;\n\n// Move system through resolved state\nflow.set(\"securityState\", \"resolved\");\nflow.set(\"intrusion\", intrusion);\n\n// Build event before clearing intrusion\nmsg.event = {\n    type: \"ALARM_OFF\",\n    reason: resolutionType,\n    note,\n    intrusionId: intrusion.id,\n    ts: now,\n    state: \"resolved\",\n    evidence: intrusion.confirmedBy || []\n};\n\nmsg.statusUpdate = {\n    armed: true,\n    state: \"resolved\",\n    intrusionId: intrusion.id,\n    evidence: intrusion.confirmedBy || [],\n    ts: now\n};\n\nmsg.mqttTopic = \"vehicle/security/status\";\nmsg.mqttPayload = {\n    armed: true,\n    state: \"resolved\",\n    intrusionId: intrusion.id,\n    evidence: intrusion.confirmedBy || [],\n    ts: now\n};\n\nmsg.statusCode = 200;\nmsg.payload = {\n    ok: true,\n    message: \"Resolved\",\n    intrusionId: intrusion.id,\n    state: \"resolved\",\n    ts: now\n};\n\n// IMPORTANT: clear the intrusion after building the event/response\nflow.set(\"intrusion\", {\n    id: null,\n    startedAt: null,\n    lastEvidenceAt: null,\n    confirmedBy: [],\n    videoRecording: false,\n    status: \"closed\",\n    closedAt: now\n});\n\n// Return system to normal after resolution\nflow.set(\"securityState\", \"normal\");\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
