    {
        "id": "03a7735eb8d49cc1",
        "type": "grovepi-ultrasonic",
        "z": "0e992f61a706eb58",
        "g": "0608b5f4d7a72b5a",
        "name": "Driver Seat Range Sensor",
        "mode": "timer",
        "interval": 1,
        "unit": "s",
        "pin": "5",
        "sensorname": "Ultrasonic Ranger",
        "sensorid": "grovepi.ultrasonic-ranger.1",
        "x": 1470,
