    {
        "id": "046dc45923aa5596",
        "type": "link in",
        "z": "0e992f61a706eb58",
        "g": "be9c8d8a9e47d8d2",
        "name": "From Baseline Capture",
        "links": [
            "1e6ecf529f287354"
        ],
        "x": 1375,
        "y": 460,
        "wires": [
            [
                "72306b47b1bb7e82"
            ]
