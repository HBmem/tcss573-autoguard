    },
    {
        "id": "5921bbfc575a0b88",
        "type": "mqtt in",
        "z": "0e992f61a706eb58",
        "g": "93149a58644b3b8a",
        "name": "Pi2 Sensor Bundle In",
        "topic": "vehicle/pi2/sensors",
        "qos": "1",
        "datatype": "auto-detect",
        "broker": "mqtt_broker_pi1",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 1460,
        "y": 680,
        "wires": [
            [
                "2c91b78b561f1c10"
            ]
        ]
    },
    {
        "id": "2c91b78b561f1c10",
        "type": "json",
        "z": "0e992f61a706eb58",
        "g": "93149a58644b3b8a",
        "name": "Parse Pi2 Payload",
        "property": "payload",
        "action": "obj",
        "pretty": false,
        "x": 1690,
        "y": 680,
        "wires": [
            [
                "c2c555de1b5b0a6c"
            ]
        ]
    },
    {
        "id": "c2c555de1b5b0a6c",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "93149a58644b3b8a",
        "name": "Normalize Pi2 Sensor Bundle",
        "func": "/**\n * Normalize the Pi 2 sensor bundle and update latest cached readings.\n */\nconst now = Date.now();\nconst p = msg.payload || {};\nconst last = flow.get(\"last\") || {};\n\nif (p.vibration !== undefined) {\n    last.vibration = Number(p.vibration);\n    last.vibrationAt = p.ts || now;\n}\n\nif (p.accel) {\n    const x = Number(p.accel.x || 0);\n    const y = Number(p.accel.y || 0);\n    const z = Number(p.accel.z || 0);\n    last.accelMag = Math.sqrt((x * x) + (y * y) + (z * z));\n    last.accelAt = p.ts || now;\n}\n\nflow.set(\"last\", last);\n\nmsg.payload = {\n    sensor: \"pi2_bundle\",\n    vibration: last.vibration,\n    accelMag: last.accelMag,\n    ts: p.ts || now\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1940,
        "y": 680,
        "wires": [
            [
                "45716de8bb60743b"
            ]
        ]
    },
    {
        "id": "ced47629dad00272",
        "type": "link in",
        "z": "0e992f61a706eb58",
        "g": "b504de31678f72cd",
        "name": "Ultrasonic Reading In",
        "links": [
            "bf5c2108be768111"
        ],
        "x": 1375,
        "y": 820,
        "wires": [
            [
                "45716de8bb60743b"
            ]
        ]
    },
    {
        "id": "45716de8bb60743b",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "93149a58644b3b8a",
        "name": "Security Detection Engine",
        "func": "/**\n * Unified detection engine for GrovePi 1 and Pi 2 readings.\n * Low-level sensor:\n * - ultrasonic -> suspicious\n *\n * High-level sensors:\n * - vibration\n * - accelerometer magnitude\n *\n * High-level evidence can trigger alarm without seat occupancy.\n */\nconst now = Date.now();\nconst armed = Boolean(flow.get(\"armed\"));\nlet state = flow.get(\"securityState\") || \"inactive\";\nconst settings = flow.get(\"settings\") || {};\nconst baseline = flow.get(\"baseline\") || {};\nconst last = flow.get(\"last\") || {};\nlet intrusion = flow.get(\"intrusion\") || {};\nconst resolvedUntil = flow.get(\"resolvedUntil\");\n\nif (!armed) {\n    return null;\n}\n\n/**\n * Return resolved mode back to active after the short display window.\n */\nif (state === \"resolved\" && resolvedUntil && now >= resolvedUntil) {\n    flow.set(\"securityState\", \"active\");\n    flow.set(\"resolvedUntil\", null);\n\n    const currentIntrusion = flow.get(\"intrusion\") || {};\n    if (currentIntrusion.status === \"resolved\" || currentIntrusion.status === \"timed_out\") {\n        flow.set(\"intrusion\", {\n            id: null,\n            startedAt: null,\n            lastEvidenceAt: null,\n            confirmedBy: [],\n            status: \"closed\",\n            picturePath: null,\n            videoPath: null,\n            videoActive: false,\n            note: null,\n            closedAt: currentIntrusion.closedAt || now\n        });\n    }\n\n    state = \"active\";\n}\n\n/**\n * Wait until baseline exists before evaluating occupancy.\n */\nif (baseline.distanceCm === null || baseline.distanceCm === undefined) {\n    return null;\n}\n\nconst recent = (timestamp, maxMs) => Boolean(timestamp) && ((now - timestamp) <= maxMs);\n\nconst seatDelta = Math.abs((last.distanceCm ?? baseline.distanceCm) - baseline.distanceCm);\nconst seatTriggered = seatDelta >= settings.seatDeltaCm;\n\nlet seatStableSince = flow.get(\"seatStableSince\") || null;\nif (seatTriggered) {\n    if (!seatStableSince) {\n        seatStableSince = now;\n        flow.set(\"seatStableSince\", seatStableSince);\n    }\n} else {\n    flow.set(\"seatStableSince\", null);\n    seatStableSince = null;\n}\n\nconst seatDebounced = Boolean(seatStableSince) && ((now - seatStableSince) >= settings.seatDebounceMs);\n\nconst vibrationTriggered =\n    Number(last.vibration || 0) >= settings.vibrationSpike &&\n    recent(last.vibrationAt, settings.confirmWindowMs);\n\nconst accelTriggered =\n    Number(last.accelMag || 0) >= settings.accelMagSpike &&\n    recent(last.accelAt, settings.confirmWindowMs);\n\nconst lowEvidence = [];\nconst highEvidence = [];\n\nif (seatDebounced) lowEvidence.push(\"ultrasonic\");\nif (vibrationTriggered) highEvidence.push(\"vibration\");\nif (accelTriggered) highEvidence.push(\"accel\");\n\nconst allEvidence = [...lowEvidence, ...highEvidence];\nconst suspiciousModeEnabled = Boolean(settings.suspiciousModeEnabled);\n\nconst ensureOpenIntrusion = () => {\n    if (!intrusion.id || intrusion.status !== \"open\") {\n        intrusion = {\n            id: `intr_${now}`,\n            startedAt: now,\n            lastEvidenceAt: now,\n            confirmedBy: [],\n            status: \"open\",\n            picturePath: null,\n            videoPath: null,\n            note: null,\n            closedAt: null\n        };\n    } else {\n        intrusion.lastEvidenceAt = now;\n    }\n};\n\nlet event = null;\nlet nextState = state;\n\n/**\n * ACTIVE -> SUSPICIOUS or ALARM\n */\nif (state === \"active\") {\n    const shouldAlarmImmediately =\n        highEvidence.length >= 1 || (lowEvidence.length >= 1 && highEvidence.length >= 1);\n\n    if (shouldAlarmImmediately || (!suspiciousModeEnabled && lowEvidence.length >= 1)) {\n        ensureOpenIntrusion();\n        intrusion.confirmedBy = Array.from(new Set([...(intrusion.confirmedBy || []), ...allEvidence]));\n        nextState = \"alarm\";\n        event = {\n            type: \"ALARM_ON\",\n            reason: shouldAlarmImmediately ? \"high_level_sensor\" : \"suspicious_mode_disabled\",\n            intrusionId: intrusion.id,\n            evidence: intrusion.confirmedBy,\n            state: nextState,\n            ts: now\n        };\n    } else if (lowEvidence.length >= 1 && suspiciousModeEnabled) {\n        ensureOpenIntrusion();\n        intrusion.confirmedBy = Array.from(new Set([...(intrusion.confirmedBy || []), ...lowEvidence]));\n        nextState = \"suspicious\";\n        event = {\n            type: \"INFO_SUSPICIOUS\",\n            reason: \"seat_delta\",\n            intrusionId: intrusion.id,\n            evidence: intrusion.confirmedBy,\n            state: nextState,\n            ts: now\n        };\n    }\n}\n\n/**\n * SUSPICIOUS -> ALARM or timeout back to ACTIVE\n */\nelse if (state === \"suspicious\") {\n    ensureOpenIntrusion();\n\n    if (highEvidence.length >= 1) {\n        intrusion.confirmedBy = Array.from(new Set([...(intrusion.confirmedBy || []), ...allEvidence]));\n        nextState = \"alarm\";\n        event = {\n            type: \"ALARM_ON\",\n            reason: \"confirmed_after_suspicious\",\n            intrusionId: intrusion.id,\n            evidence: intrusion.confirmedBy,\n            state: nextState,\n            ts: now\n        };\n    } else if ((now - intrusion.startedAt) >= settings.suspiciousTimeoutMs) {\n        intrusion.status = \"timed_out\";\n        intrusion.closedAt = now;\n        nextState = \"active\";\n        event = {\n            type: \"ALARM_OFF\",\n            reason: \"suspicious_timeout\",\n            intrusionId: intrusion.id,\n            evidence: intrusion.confirmedBy || [],\n            picturePath: intrusion.picturePath || \"\",\n            videoPath: intrusion.videoPath || \"\",\n            state: nextState,\n            ts: now\n        };\n    }\n}\n\n/**\n * Ignore detection while already in alarm.\n */\nelse if (state === \"alarm\") {\n    if (intrusion.id && intrusion.status === \"open\") {\n        intrusion.lastEvidenceAt = now;\n        intrusion.confirmedBy = Array.from(new Set([...(intrusion.confirmedBy || []), ...allEvidence]));\n        flow.set(\"intrusion\", intrusion);\n    }\n    return null;\n}\n\nif (!event) {\n    return null;\n}\n\nflow.set(\"securityState\", nextState);\n\nif (event.type === \"ALARM_OFF\" && event.reason === \"suspicious_timeout\") {\n    flow.set(\"intrusion\", intrusion);\n} else {\n    flow.set(\"intrusion\", intrusion);\n}\n\nreturn {\n    event,\n    statusUpdate: {\n        armed: true,\n        state: nextState,\n        intrusionId: event.intrusionId || intrusion.id || null,\n        evidence: intrusion.confirmedBy || [],\n        ts: now\n    }\n};",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
