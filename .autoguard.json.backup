            ]
        ]
    },
    {
        "id": "f6fe70541e8bda69",
        "type": "json",
        "z": "0e992f61a706eb58",
        "g": "38d9086a2977fa73",
        "name": "Parse Resolve Request",
        "property": "payload",
        "action": "obj",
        "pretty": false,
        "x": 410,
        "y": 600,
        "wires": [
            [
                "ce0dd89034e3f85a"
            ]
        ]
    },
    {
        "id": "ce0dd89034e3f85a",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "38d9086a2977fa73",
        "name": "Resolve Active Alarm",
        "func": "/**\n * Resolve an active suspicious/alarm incident from the dashboard.\n * Keeps the original HTTP msg so the http response node can reply correctly.\n */\nconst now = Date.now();\nconst body = msg.payload || {};\nconst armed = Boolean(flow.get(\"armed\"));\nconst intrusion = flow.get(\"intrusion\") || {};\n\nif (!armed) {\n    msg.statusCode = 400;\n    msg.payload = { ok: false, error: \"System is not armed\", ts: now };\n    return [msg, null, null, null];\n}\n\nif (!intrusion.id || intrusion.status !== \"open\") {\n    msg.statusCode = 409;\n    msg.payload = { ok: false, error: \"No active intrusion\", ts: now };\n    return [msg, null, null, null];\n}\n\nif (body.intrusionId && body.intrusionId !== intrusion.id) {\n    msg.statusCode = 409;\n    msg.payload = {\n        ok: false,\n        error: \"Intrusion ID mismatch\",\n        activeIntrusionId: intrusion.id,\n        requestedIntrusionId: body.intrusionId,\n        ts: now\n    };\n    return [msg, null, null, null];\n}\n\nintrusion.status = \"resolved\";\nintrusion.closedAt = now;\nintrusion.note = body.note || \"Resolved by user\";\n\nflow.set(\"intrusion\", intrusion);\nflow.set(\"securityState\", \"resolved\");\nflow.set(\"resolvedUntil\", now + 5000);\n\nconst eventMsg = RED.util.cloneMessage(msg);\neventMsg.event = {\n    type: \"ALARM_OFF\",\n    reason: body.resolutionType || \"user_resolved\",\n    note: intrusion.note,\n    intrusionId: intrusion.id,\n    evidence: intrusion.confirmedBy || [],\n    picturePath: intrusion.picturePath || \"\",\n    videoPath: intrusion.videoPath || \"\",\n    state: \"resolved\",\n    ts: now\n};\neventMsg.statusUpdate = {\n    armed: true,\n    state: \"resolved\",\n    intrusionId: intrusion.id,\n    evidence: intrusion.confirmedBy || [],\n    ts: now\n};\n\nconst mqttMsg = RED.util.cloneMessage(msg);\nmqttMsg.topic = \"vehicle/security/status\";\nmqttMsg.payload = eventMsg.statusUpdate;\n\nmsg.statusCode = 200;\nmsg.payload = {\n    ok: true,\n    message: \"Intrusion resolved\",\n    intrusionId: intrusion.id,\n    state: \"resolved\",\n    ts: now\n};\n\nreturn [msg, mqttMsg, eventMsg, eventMsg];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 660,
