    {
        "id": "ea91053b0fb8900e",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "c493a96ad53dfc0d",
        "name": "Build Status Response",
        "func": "/**\n * Return current system status for the dashboard.\n */\nconst payload = {\n    armed: Boolean(flow.get(\"armed\")),\n    state: flow.get(\"securityState\") || \"inactive\",\n    settings: flow.get(\"settings\") || {},\n    baseline: flow.get(\"baseline\") || {},\n    last: flow.get(\"last\") || {},\n    intrusion: flow.get(\"intrusion\") || {},\n    alarm: flow.get(\"alarm\") || {},\n    ts: Date.now()\n};\n\nmsg.payload = payload;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
