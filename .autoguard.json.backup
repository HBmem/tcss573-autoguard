    {
        "id": "d72cb34042a5585a",
        "type": "json",
        "z": "78e53885bf1abe0d",
        "g": "6dea70e55d392fe6",
        "name": "Parse Trigger Alarm Body",
        "property": "payload",
        "action": "",
        "pretty": false,
        "x": 1150,
        "y": 1140,
        "wires": [
            [
                "5fda78ba799cb757"
            ]
        ]
    },
    {
        "id": "5fda78ba799cb757",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "6dea70e55d392fe6",
        "name": "forceTriggerAlarm",
        "func": "// Function node: forceTriggerAlarm\n// Outputs:\n// 1 = HTTP response\n// 2 = alarm event/status/logging fanout\n// 3 = unused/debug\n\nconst now = Date.now();\nconst armed = Boolean(flow.get(\"armed\"));\nlet state = flow.get(\"securityState\") || \"inactive\";\nlet intrusion = flow.get(\"intrusion\") || {\n    id: null,\n    startedAt: null,\n    lastEvidenceAt: null,\n    confirmedBy: [],\n    videoRecording: false,\n    status: \"closed\",\n    closedAt: null\n};\n\nconst body = msg.payload || {};\nconst requestedIntrusionId = body.intrusionId || null;\nconst note = body.note || \"Alarm triggered by dashboard user\";\nconst triggerSource = body.triggerSource || \"dashboard_user_confirmation\";\n\n// Reject if system not armed\nif (!armed) {\n    return [\n        {\n            statusCode: 400,\n            payload: {\n                ok: false,\n                error: \"System is not armed\",\n                ts: now\n            }\n        },\n        null,\n        null\n    ];\n}\n\n// Reject if there is no active intrusion\nif (!intrusion.id || intrusion.status !== \"open\") {\n    return [\n        {\n            statusCode: 409,\n            payload: {\n                ok: false,\n                error: \"No active intrusion available to escalate\",\n                ts: now\n            }\n        },\n        null,\n        null\n    ];\n}\n\n// Reject if the request refers to a different intrusion than the active one\nif (requestedIntrusionId && intrusion.id !== requestedIntrusionId) {\n    return [\n        {\n            statusCode: 409,\n            payload: {\n                ok: false,\n                error: \"Intrusion ID does not match the active intrusion\",\n                activeIntrusionId: intrusion.id,\n                requestedIntrusionId,\n                ts: now\n            }\n        },\n        null,\n        null\n    ];\n}\n\n// Only allow escalation from suspicious or normal open-intrusion paths\nif (state !== \"suspicious\" && state !== \"normal\") {\n    return [\n        {\n            statusCode: 409,\n            payload: {\n                ok: false,\n                error: `Cannot force alarm from current state: ${state}`,\n                intrusionId: intrusion.id,\n                ts: now\n            }\n        },\n        null,\n        null\n    ];\n}\n\n// Escalate current intrusion to alarm\nstate = \"alarm\";\nintrusion.status = \"open\";\nintrusion.lastEvidenceAt = now;\n\n// Add dashboard/user confirmation as evidence trail if not already present\nconst existingEvidence = Array.isArray(intrusion.confirmedBy) ? intrusion.confirmedBy : [];\nintrusion.confirmedBy = Array.from(\n    new Set([...existingEvidence, \"dashboard_confirmed\"])\n);\n\n// Persist updated state\nflow.set(\"securityState\", state);\nflow.set(\"intrusion\", intrusion);\n\n// Build the shared event your existing ALARM_ON switch can use\nconst alarmEvent = {\n    type: \"ALARM_ON\",\n    reason: \"user_requested_alarm\",\n    intrusionId: intrusion.id,\n    evidence: intrusion.confirmedBy,\n    triggerSource,\n    note,\n    armed: true,\n    state: \"alarm\",\n    ts: now\n};\n\n// This second output can be wired to:\n// - Alarm Activation link out\n// - MQTT status out\n// - Influx logging link out\nconst eventMsg = {\n    event: alarmEvent,\n    statusUpdate: {\n        armed: true,\n        state: \"alarm\",\n        intrusionId: intrusion.id,\n        evidence: intrusion.confirmedBy,\n        ts: now\n    },\n    mqttTopic: \"vehicle/security/status\",\n    mqttPayload: {\n        armed: true,\n        state: \"alarm\",\n        intrusionId: intrusion.id,\n        evidence: intrusion.confirmedBy,\n        ts: now\n    },\n    payload: {\n        ok: true,\n        message: \"Alarm triggered\",\n        intrusionId: intrusion.id,\n        state: \"alarm\",\n        ts: now\n    }\n};\n\n// Output 1: HTTP response\nconst responseMsg = {\n    statusCode: 200,\n    payload: {\n        ok: true,\n        message: \"Alarm triggered\",\n        intrusionId: intrusion.id,\n        state: \"alarm\",\n        ts: now\n    }\n};\n\nreturn [responseMsg, eventMsg, null];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
