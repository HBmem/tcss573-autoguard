    {
        "id": "fa89397cc634bc5a",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "ddbc521e6b96d5b1",
        "name": "Build Image File Path",
        "func": "/**\n * Build the absolute path for an image request.\n * Only allows safe filenames to prevent path traversal.\n *\n * Outputs:\n * 1 = valid file read request\n * 2 = immediate HTTP error response\n */\nconst filename = msg.req?.params?.filename || \"\";\n\n// Allow only simple filenames such as:\n// intr_1773108166477.jpg\nif (!/^[a-zA-Z0-9._-]+$/.test(filename)) {\n    msg.statusCode = 400;\n    msg.headers = {\n        \"Content-Type\": \"application/json\"\n    };\n    msg.payload = {\n        ok: false,\n        error: \"Invalid filename\"\n    };\n    return [null, msg];\n}\n\nmsg.filename = \"/home/pi/autoguard/images/\" + filename;\nmsg.requestedFile = filename;\n\nreturn [msg, null];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
