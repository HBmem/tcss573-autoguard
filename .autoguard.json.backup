    },
    {
        "id": "3a427980db1f8657",
        "type": "link out",
        "z": "78e53885bf1abe0d",
        "g": "0a589b864fc903a5",
        "name": "Arm/Disarm Out",
        "mode": "link",
        "links": [
            "f82d905a91cb1b3c"
        ],
