    {
        "id": "19c56bf46d9bdbff",
        "type": "http in",
        "z": "78e53885bf1abe0d",
        "g": "6dea70e55d392fe6",
        "name": "Trigger Alarm",
        "url": "/api/trigger-alarm",
        "method": "post",
        "upload": false,
        "skipBodyParsing": false,
        "swaggerDoc": "",
        "x": 930,
