    {
        "id": "107f5053e5127f4a",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "6a072c52208fa8e8",
        "name": "buildCameraCommands",
        "func": "// Function node: buildCameraCommands\n// Builds msg.command for Exec node.\n// Adjust paths + command depending on your Pi camera stack.\n// We'll create a per-intrusion filename so you can later store/reference it.\n\nconst ev = msg.event || {};\nconst intrusionId = ev.intrusionId || `intr_${Date.now()}`;\n\nconst baseDir = \"/home/pi/vehicle_security\";\nconst vidPath = `${baseDir}/videos/${intrusionId}.h264`;\nconst pidPath = `${baseDir}/videos/${intrusionId}.pid`;\n\nif (ev.type === \"ALARM_ON\") {\n    // Start recording (background) and save PID so we can stop it.\n    // Option A: libcamera-vid (newer)\n    msg.command = `bash -lc 'mkdir -p ${baseDir}/videos && (libcamera-vid -t 0 -o ${vidPath} --inline --nopreview >/dev/null 2>&1 & echo $! > ${pidPath})'`;\n    msg.videoPath = vidPath;\n    return msg;\n}\n\nif (ev.type === \"ALARM_AUTO_RESOLVE\" || ev.type === \"ALARM_OFF\") {\n    // Stop recording if running\n    msg.command = `bash -lc 'if [ -f ${pidPath} ]; then kill $(cat ${pidPath}) >/dev/null 2>&1; rm -f ${pidPath}; fi'`;\n    msg.videoPath = vidPath;\n    return msg;\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1310,
        "y": 740,
        "wires": [
            [
                "7490ea89556eef65",
                "369b20bf741f25f8"
            ]
        ]
    },
    {
        "id": "9f10f25ed97310e9",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "6a072c52208fa8e8",
        "name": "alarmOff",
        "func": "// Function node: alarmOff\nflow.set(\"alertActive\", false);\nflow.set(\"alertTickN\", 0);\nflow.set(\"alertLedState\", 0);\n\n// output 1: direct off command to LED + buzzer\n// output 2: reset command for trigger\nreturn [\n    { payload: 0 },\n    { reset: true }\n];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1260,
        "y": 620,
        "wires": [
            [
                "ad9c14766df20cba",
                "07d1b91ec18aed49"
            ],
            [
                "95f297c866b9e056"
            ]
        ]
    },
    {
        "id": "c2f8ddb63c6a96fa",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "6a072c52208fa8e8",
        "name": "alarmOn",
        "func": "// Function node: alarmOn\n\nconst ctl = msg.control || {};\nconst ev = msg.event || {};\n\nconst shouldStart =\n    ctl.action === \"start\" ||\n    ev.type === \"ALARM_ON\";\n\nif (!shouldStart) return null;\n\nflow.set(\"alertActive\", true);\n\n// Reset LED/tick state for a fresh alert cycle\nflow.set(\"alertLedState\", 0);\nflow.set(\"alertTickN\", 0);\n\n// Prefer intrusion id from control, otherwise from event\nflow.set(\"alertIntrusionId\", ctl.intrusionId || ev.intrusionId || null);\n\n// Optional: preserve reason/source for debugging\nflow.set(\"alertReason\", ev.reason || ctl.reason || null);\nflow.set(\"alertTriggerSource\", ev.triggerSource || null);\n\nmsg.tick = { ts: Date.now(), n: 0 };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
