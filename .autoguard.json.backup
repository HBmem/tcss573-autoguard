    {
        "id": "61907aef6129413e",
        "type": "comment",
        "z": "78e53885bf1abe0d",
        "g": "426fa63401e03052",
        "name": "Initialize Device",
        "info": "",
        "x": 200,
        "y": 160,
        "wires": []
    },
    {
        "id": "a325bd150a82429f",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "eecac3e1703cb385",
        "name": "securityCore",
        "func": "// Function node: securityCore\n// Input: msg.reading from ultrasonic or pi2 bundle\n// Output: msg.event describing what happened + msg.statusUpdate for publishing/logging\n\nconst armed = Boolean(flow.get(\"armed\"));\nconst thresholds = flow.get(\"thresholds\") || {};\nconst baseline = flow.get(\"baseline\") || { distanceCm: null };\nconst last = flow.get(\"last\") || {};\nlet state = flow.get(\"securityState\") || \"inactive\";\n\n// intrusion object now includes lifecycle flags\nlet intrusion = flow.get(\"intrusion\") || {\n    id: null,\n    startedAt: null,\n    lastEvidenceAt: null,\n    confirmedBy: [],\n    videoRecording: false,\n    status: \"closed\",          // open | resolved | timed_out | closed\n    closedAt: null\n};\n\nconst now = Date.now();\nconst reading = msg.reading || {};\nconst events = [];\n\n// Use 1 minutes for suspicious timeout\nconst suspiciousTimeoutMs = 1 * 60 * 1000;\n\n// If not armed: do nothing besides allow logging if you want\nif (!armed) {\n    state = \"inactive\";\n    flow.set(\"securityState\", state);\n    return null;\n}\n\n// Helper: compute seat delta\nconst baseD = baseline?.distanceCm;\nconst curD = last?.distanceCm;\nconst seatDelta = (baseD !== null && curD !== null) ? Math.abs(curD - baseD) : null;\nconst seatTriggered = (seatDelta !== null && seatDelta >= thresholds.seatDeltaCm);\n\n// Helper: check confirmers (recent enough)\nconst recent = (t, maxMs) => (t && (now - t) <= maxMs);\nconst confirmWindowMs = 4000;\n\nconst soundConfirm = (last.sound !== null && last.sound >= thresholds.soundSpike && recent(last.soundAt, confirmWindowMs));\nconst vibConfirm = (last.vibration !== null && last.vibration >= thresholds.vibrationSpike && recent(last.vibrationAt, confirmWindowMs));\nconst accelConfirm = (last.accelMag !== null && last.accelMag >= thresholds.accelMagSpike && recent(last.accelAt, confirmWindowMs));\n\nconst confirmers = [];\nif (seatTriggered) confirmers.push(\"ultrasonic\");\nif (soundConfirm) confirmers.push(\"sound\");\nif (vibConfirm) confirmers.push(\"vibration\");\nif (accelConfirm) confirmers.push(\"accel\");\n\n// Debounce seat trigger: require stable trigger across seatDebounceMs\nconst seatStableKey = \"seatStableSince\";\nlet seatStableSince = flow.get(seatStableKey);\nif (seatTriggered) {\n    if (!seatStableSince) seatStableSince = now;\n    flow.set(seatStableKey, seatStableSince);\n} else {\n    flow.set(seatStableKey, null);\n    seatStableSince = null;\n}\nconst seatDebounced = seatStableSince && (now - seatStableSince) >= thresholds.seatDebounceMs;\n\n// Decide transitions\nconst hasStrongEvidence = confirmers.length >= 2;\nconst hasOnlySeat = seatDebounced && confirmers.length === 1 && confirmers[0] === \"ultrasonic\";\n\n// Only create a new intrusion if there is no currently open one\nconst ensureIntrusion = () => {\n    const isOpen = intrusion.id && (intrusion.status === \"open\");\n    if (!isOpen) {\n        intrusion = {\n            id: `intr_${now}`,\n            startedAt: now,\n            lastEvidenceAt: now,\n            confirmedBy: [],\n            videoRecording: false,\n            status: \"open\",\n            closedAt: null\n        };\n    } else {\n        intrusion.lastEvidenceAt = now;\n    }\n};\n\n// NORMAL behavior\nif (state === \"normal\") {\n    if (hasOnlySeat) {\n        ensureIntrusion();\n        intrusion.confirmedBy = Array.from(new Set([...(intrusion.confirmedBy || []), \"ultrasonic\"]));\n        state = \"suspicious\";\n        events.push({\n            type: \"INFO_OCCUPANCY\",\n            reason: \"seat_delta\",\n            evidence: [\"ultrasonic\"],\n            seatDeltaCm: seatDelta,\n            distanceCm: curD,\n            baselineCm: baseD\n        });\n    } else if (seatDebounced && hasStrongEvidence) {\n        ensureIntrusion();\n        intrusion.confirmedBy = Array.from(new Set([...(intrusion.confirmedBy || []), ...confirmers]));\n        state = \"alarm\";\n        events.push({\n            type: \"ALARM_ON\",\n            reason: \"sensor_fusion\",\n            evidence: intrusion.confirmedBy,\n            seatDeltaCm: seatDelta,\n            distanceCm: curD,\n            baselineCm: baseD,\n            sound: last.sound,\n            vibration: last.vibration,\n            accelMag: last.accelMag\n        });\n    } else {\n        return null;\n    }\n}\n\n// SUSPICIOUS behavior\nelse if (state === \"suspicious\") {\n    // if suspicious already exists, do not generate a new ID\n    if (!intrusion.id || intrusion.status !== \"open\") {\n        ensureIntrusion();\n    } else {\n        intrusion.lastEvidenceAt = now;\n    }\n\n    if (seatDebounced && hasStrongEvidence) {\n        intrusion.confirmedBy = Array.from(new Set([...(intrusion.confirmedBy || []), ...confirmers]));\n        state = \"alarm\";\n        events.push({\n            type: \"ALARM_ON\",\n            reason: \"confirmed_after_suspicious\",\n            evidence: intrusion.confirmedBy\n        });\n    } else {\n        const started = intrusion.startedAt ?? now;\n        if ((now - started) >= suspiciousTimeoutMs) {\n            state = \"normal\";\n            intrusion.status = \"timed_out\";\n            intrusion.closedAt = now;\n            events.push({\n                type: \"SUSPICIOUS_TIMEOUT\",\n                reason: \"no_confirmation\"\n            });\n            // Keep the timed-out intrusion record for this message,\n            // then clear AFTER publishing below.\n        } else {\n            return null;\n        }\n    }\n}\n\n// ALARM behavior\nelse if (state === \"alarm\") {\n    if (!intrusion.id || intrusion.status !== \"open\") {\n        ensureIntrusion();\n    } else {\n        intrusion.lastEvidenceAt = now;\n    }\n\n    const minOk = intrusion.startedAt && (now - intrusion.startedAt) >= thresholds.alarmMinMs;\n    const quietFor = intrusion.lastEvidenceAt ? (now - intrusion.lastEvidenceAt) : 0;\n\n    intrusion.confirmedBy = Array.from(new Set([...(intrusion.confirmedBy || []), ...confirmers]));\n\n    if (minOk && quietFor >= 6000) {\n        state = \"resolved\";\n        intrusion.status = \"resolved\";\n        intrusion.closedAt = now;\n        events.push({\n            type: \"ALARM_AUTO_RESOLVE\",\n            reason: \"quiet_period\"\n        });\n    } else {\n        return null;\n    }\n}\n\n// RESOLVED behavior\nelse if (state === \"resolved\") {\n    // Do not create a new ID here. Just transition back to normal.\n    state = \"normal\";\n    events.push({\n        type: \"RESOLVED_TO_NORMAL\"\n    });\n}\n\n// Persist current state before building outgoing messages\nflow.set(\"securityState\", state);\nflow.set(\"intrusion\", intrusion);\n\nconst mainEvent = events[0];\nif (!mainEvent) return null;\n\nmsg.event = {\n    ...mainEvent,\n    intrusionId: intrusion.id,\n    armed: true,\n    state,\n    ts: now\n};\n\nmsg.statusUpdate = {\n    armed: true,\n    state,\n    intrusionId: intrusion.id,\n    evidence: intrusion.confirmedBy || [],\n    ts: now\n};\n\n// AFTER event/status are built, clear the closed intrusion record so the next true incident can get a new ID\nif (intrusion.status === \"resolved\" || intrusion.status === \"timed_out\") {\n    flow.set(\"intrusion\", {\n        id: null,\n        startedAt: null,\n        lastEvidenceAt: null,\n        confirmedBy: [],\n        videoRecording: false,\n        status: \"closed\",\n        closedAt: intrusion.closedAt || now\n    });\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
