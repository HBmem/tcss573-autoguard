    },
    {
        "id": "abd2ccc7d536c490",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "0608b5f4d7a72b5a",
        "name": "Normalize Distance Reading",
        "func": "/**\n * Normalize ultrasonic readings and store the latest distance reading.\n */\nconst now = Date.now();\nconst distanceCm = typeof msg.payload === \"number\"\n    ? Number(msg.payload)\n    : Number(msg.payload?.distance ?? msg.payload?.cm);\n\nconst last = flow.get(\"last\") || {};\nlast.distanceCm = distanceCm;\nlast.distanceAt = now;\nflow.set(\"last\", last);\n\nmsg.payload = {\n    sensor: \"ultrasonic\",\n    distanceCm,\n    ts: now\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
