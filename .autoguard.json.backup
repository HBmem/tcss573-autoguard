    {
        "id": "9932d1a9eb8e9e30",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "7404463c72010353",
        "name": "Build Security Event Point",
        "func": "/**\n * Save security events with sensor snapshot context.\n * Falls back to the current intrusion record for media paths.\n */\nconst event = msg.event || {};\nconst last = flow.get(\"last\") || {};\nconst baseline = flow.get(\"baseline\") || {};\nconst intrusion = flow.get(\"intrusion\") || {};\n\nconst picturePath = event.picturePath || intrusion.picturePath || \"\";\nconst videoPath = event.videoPath || intrusion.videoPath || \"\";\n\nmsg.payload = {\n    measurement: \"security_events\",\n    tags: {\n        device: \"pi1\",\n        intrusionId: event.intrusionId || \"none\",\n        type: event.type || \"unknown\"\n    },\n    fields: {\n        state: String(event.state || flow.get(\"securityState\") || \"unknown\"),\n        reason: String(event.reason || \"\"),\n        evidence: JSON.stringify(event.evidence || []),\n        picture_path: String(picturePath),\n        video_path: String(videoPath),\n        distance_cm: last.distanceCm ?? null,\n        baseline_cm: baseline.distanceCm ?? null,\n        vibration: last.vibration ?? null,\n        accel_mag: last.accelMag ?? null\n    },\n    timestamp: new Date(event.ts || Date.now())\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 270,
        "y": 1340,
        "wires": [
