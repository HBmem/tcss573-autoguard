    {
        "id": "0b0a2730b9605d76",
        "type": "inject",
        "z": "0e992f61a706eb58",
        "g": "dfaa92d4dd849eab",
        "name": "Start Device",
        "props": [],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
        "x": 170,
        "y": 160,
