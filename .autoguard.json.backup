    {
        "id": "dedbe14c1df4bd31",
        "type": "function",
        "z": "0e992f61a706eb58",
        "g": "2dc032b30fb2cdf3",
        "name": "Store Live Feed Event",
        "func": "/**\n * Store recent live feed events for dashboard polling.\n * Keeps only the newest 50 events in memory.\n */\nconst event = msg.event || null;\nconst intrusion = flow.get(\"intrusion\") || {};\n\nif (!event) {\n    return null;\n}\n\nconst feed = flow.get(\"liveFeedEvents\") || [];\n\nconst entry = {\n    type: event.type || \"UNKNOWN\",\n    reason: event.reason || \"\",\n    intrusionId: event.intrusionId || null,\n    evidence: Array.isArray(event.evidence) ? event.evidence : [],\n    state: event.state || (flow.get(\"securityState\") || \"inactive\"),\n    picturePath: event.picturePath || intrusion.picturePath || \"\",\n    videoPath: event.videoPath || intrusion.videoPath || \"\",\n    note: event.note || \"\",\n    ts: event.ts || Date.now()\n};\n\nfeed.unshift(entry);\n\nflow.set(\"liveFeedEvents\", feed.slice(0, 50));\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
