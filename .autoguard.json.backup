    {
        "id": "9798cd4bac5c5e10",
        "type": "function",
        "z": "78e53885bf1abe0d",
        "g": "6a072c52208fa8e8",
        "name": "Alarm Tick Router",
        "func": "// Function node: Alert Tick Router\n// outputs: 2\n// output 1 = buzzer path\n// output 2 = LED path\n\nconst active = Boolean(flow.get(\"alertActive\"));\n\nif (!active) {\n    return [null, null];\n}\n\nlet n = flow.get(\"alertTickN\") || 0;\nn += 1;\nflow.set(\"alertTickN\", n);\n\nconst buzzerMsg = {\n    payload: 1,\n    tick: { ts: Date.now(), n }\n};\n\nconst ledMsg = {\n    tick: { ts: Date.now(), n }\n};\n\nreturn [buzzerMsg, ledMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
